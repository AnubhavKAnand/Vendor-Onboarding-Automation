COLUMN TABLE vendorportal_ApprovalReview (
  ID NVARCHAR(36) NOT NULL,
  createdAt TIMESTAMP,
  createdBy NVARCHAR(255),
  modifiedAt TIMESTAMP,
  modifiedBy NVARCHAR(255),
  Vendor_ID NVARCHAR(36) NOT NULL,
  ReviewerName NVARCHAR(200),
  Department NVARCHAR(100),
  Decision NVARCHAR(50),
  Comments NCLOB,
  ReviewDate DATE,
  PRIMARY KEY(ID)
) WITH ASSOCIATIONS (
  MANY TO ONE JOIN vendorportal_Vendor AS Vendor ON (Vendor.ID = Vendor_ID)
)